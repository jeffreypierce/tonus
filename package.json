{
  "name": "tonus",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "description": "Medieval music analysis — GABC, plainchant, tuning, liturgy, ephemeris",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc && cp src/data/psalms.json dist/data/psalms.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test --test-reporter=spec tests/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}

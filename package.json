{
  "name": "tonus",
  "version": "0.1.5",
  "private": false,
  "type": "module",
  "description": "Medieval music analysis and performance: GABC plainchant exports, liturgical calendar, tuning systems, ephemeris, and the harmony of the spheres",
  "author": "Jeffrey Pierce <jeffrey@jeffreypierce.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffreypierce/tonus.git"
  },
  "homepage": "https://jeffreypierce.github.io/tonus/",
  "bugs": "https://github.com/jeffreypierce/tonus/issues",
  "keywords": [
    "gregorian-chant",
    "gabc",
    "plainchant",
    "liturgical-calendar",
    "gregorian",
    "medieval",
    "music-theory",
    "tuning",
    "temperament",
    "solfege",
    "ephemeris",
    "musica-universalis",
    "harmony-of-the-spheres",
    "boethius",
    "divinum-officium"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "LICENSE",
    "CHANGELOG.md",
    "BIBLIOGRAPHY.md"
  ],
  "scripts": {
    "build": "tsc && cp src/data/psalms.json dist/data/psalms.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test --test-reporter=spec tests/*.test.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
